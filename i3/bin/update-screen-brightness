#!/usr/bin/env nu

def main [inc: int = 10] {
    let delta = if ($inc < 0) {
        $"($inc | math abs)%-"
    } else {
        $"($inc)%+"
    }
    ^brightnessctl set $delta

    let cur = (^brightnessctl get | into int)
    let max = (^brightnessctl max | into int)
    let percent = $cur / $max * 100 | math round
    ^notify-send -t 1000 -h $"int:value:($percent)" -h string:synchronous:brightness $"Brightness: ($percent)%"
}
