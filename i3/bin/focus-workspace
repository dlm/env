#!/usr/bin/env nu
#  Focus on a workspace

let current_workspace = (
    i3-msg -t get_workspaces
    | from json
    | where focused
    | get name
    | first
)

let choice = (
  muxwm view list --with-pins --with-unmanaged
  | from tsv --noheaders
  | rename workspace pin
  | sort-by workspace
  | each { |row| $"($row.pin | default --empty "∅"):($row.workspace)" }
  | str join "\n"
  | ~/bin/scripts/launch picker --no-custom --selected=($current_workspace) "Focus on workspace →"
  | if ($in | is-empty) { notify-send "No project selected"; exit 0 } else { $in }
  | split row ":"
  | last
  | str trim
)

# Move the focused container, then switch to that workspace
^i3-msg $"workspace \"($choice)\"" | ignore
