#!/usr/bin/env nu
#  Focus on a workspace

let choice = (
  muxwm view list --with-pins --with-unmanaged
  | from tsv --noheaders
  | sort-by column0
  | each { |row|
        let pin = if ($row.column1 | is-empty) { "∅" } else { $row.column1 }
        $"($pin):($row.column0)"
    }
  | str join "\n"
  | ~/bin/scripts/launch picker --no-custom "Focus on workspace →"
  | if ($in | is-empty) { notify-send "No project selected"; exit 0 } else { $in }
  | split column ":"
  | get column2.0
  | str trim
)

# Move the focused container, then switch to that workspace
^i3-msg $"workspace \"($choice)\"" | ignore
