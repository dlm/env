#!/usr/bin/env nu

let current_project = (
    i3-msg -t get_workspaces
    | from json
    | where focused
    | get name
    | split row '#'
    | first
)

let choice = (
  ^muxwm project list --with-pins
  | from tsv --noheaders
  | rename project pin
  | sort-by project
  | each { |row| $"($row.pin | default --empty "∅"):($row.project)" }
  | str join "\n"
  | ~/bin/scripts/launch picker --selected ($current_project) --no-custom "Focus on project →"
  | if ($in | is-empty) { notify-send "No project selected"; exit 0 } else { $in }
  | split column ":"
  | first
  | str trim
)

^muxwm project focus $choice

