#!/usr/bin/env nu

# get the active focused workspace
def get_focused_proj_name [] {
  ^i3-msg -t get_workspaces
  | from json
  | where focused
  | first
  | get name
  | split row '#'
  | first
}


def filtered [] {
  let focused_proj = (get_focused_proj_name)
  let ordered_views = (^muxwm project list-views | lines)
  let workspaces = (
    ^i3-msg -t get_workspaces
    | from json
    | where {|w| $w.focused or $w.urgent or $w.visible or ($w.name | str starts-with $focused_proj) }
  )

  $workspaces
  | each {|w|
    let idx = ($ordered_views | enumerate | where {|e| $e.item == $w.name} | first | get index)
    $w | insert order_index (if ($idx | is-empty) { 9999 } else { $idx })
  }
  | sort-by order_index
  | reject order_index
  | to json -r
}

# then on every workspace/output event, print again
^i3-msg -t subscribe -m '["workspace","output"]'
  | lines
  | each {|_| print (filtered)}
  | ignore

